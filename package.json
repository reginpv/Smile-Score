{
  "name": "nextcrud",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "dotenv -e .env.local -- npx prisma generate",
    "db:migrate": "dotenv -e .env.local -- npx prisma migrate dev --name",
    "db:push": "dotenv -e .env.local -- npx prisma db push",
    "db:reset": "dotenv -e .env.local -- npx prisma migrate reset",
    "db:deploy": "dotenv -e .env.local -- npx prisma migrate deploy",
    "db:seed": "dotenv -e .env.local -- npx prisma db seed",
    "db:studio": "dotenv -e .env.local -- npx prisma studio",
    "test": "jest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.3.3",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.5",
    "postcss": "^8.5.13",
    "prisma": "^7.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsx": "^4.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^6"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
